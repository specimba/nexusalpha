@@ -0,0 +1,146 @@
+"""VAP (Verification and Audit Protocol) proof chain implementation.
+
+This module provides L1+L2 audit trail functionality with chain integrity verification.
+"""
+from typing import Dict, List, Optional, Any
+from dataclasses import dataclass, field
+from datetime import datetime
+import hashlib
+import json
+
+
+@dataclass
+class ProofEntry:
+    """A single entry in the proof chain."""
+    entry_id: str
+    timestamp: datetime
+    agent_id: str
+    action: str
+    details: Dict[str, Any]
+    level: str = "INFO"  # INFO, WARN, ERROR, AUDIT
+    l1_hash: str = ""  # Layer 1 hash (entry-level)
+    l2_hash: str = ""  # Layer 2 hash (chain-level)
+
+    def compute_l1_hash(self) -> str:
+        """Compute L1 hash for this entry."""
+        data = {
+            "entry_id": self.entry_id,
+            "timestamp": self.timestamp.isoformat(),
+            "agent_id": self.agent_id,
+            "action": self.action,
+            "details": self.details,
+            "level": self.level
+        }
+        return hashlib.sha256(json.dumps(data, sort_keys=True).encode()).hexdigest()
+
+    def finalize(self, previous_l2_hash: str = "") -> None:
+        """Finalize entry with L1 and L2 hashes."""
+        self.l1_hash = self.compute_l1_hash()
+        # L2 hash includes previous L2 for chain integrity
+        chain_data = self.l1_hash + previous_l2_hash
+        self.l2_hash = hashlib.sha256(chain_data.encode()).hexdigest()
+
+
+class ProofChain:
+    """VAP L1+L2 proof chain for audit trail with integrity verification."""
+
+    def __init__(self):
+        self._entries: List[ProofEntry] = []
+        self._entry_index: Dict[str, ProofEntry] = {}
+        self._last_l2_hash: str = ""
+        self._counter: int = 0
+
+    def _generate_entry_id(self) -> str:
+        """Generate a unique entry ID."""
+        self._counter += 1
+        return f"proof-{self._counter:08d}"
+
+    def record(
+        self,
+        agent_id: str,
+        action: str,
+        details: Dict[str, Any],
+        level: str = "INFO"
+    ) -> ProofEntry:
+        """Record a proof chain entry."""
+        entry = ProofEntry(
+            entry_id=self._generate_entry_id(),
+            timestamp=datetime.utcnow(),
+            agent_id=agent_id,
+            action=action,
+            details=details,
+            level=level
+        )
+        entry.finalize(self._last_l2_hash)
+
+        self._entries.append(entry)
+        self._entry_index[entry.entry_id] = entry
+        self._last_l2_hash = entry.l2_hash
+
+        return entry
+
+    def get_entry(self, entry_id: str) -> Optional[ProofEntry]:
+        """Get an entry by ID."""
+        return self._entry_index.get(entry_id)
+
+    def get_entries(
+        self,
+        agent_id: Optional[str] = None,
+        level: Optional[str] = None,
+        limit: int = 100
+    ) -> List[ProofEntry]:
+        """Get entries with optional filtering."""
+        results = self._entries
+
+        if agent_id:
+            results = [e for e in results if e.agent_id == agent_id]
+        if level:
+            results = [e for e in results if e.level == level]
+
+        return results[-limit:]
+
+    def verify_chain(self) -> bool:
+        """Verify the integrity of the proof chain."""
+        previous_l2 = ""
+        for entry in self._entries:
+            expected_l1 = entry.compute_l1_hash()
+            if entry.l1_hash != expected_l1:
+                return False
+
+            expected_l2 = hashlib.sha256((entry.l1_hash + previous_l2).encode()).hexdigest()
+            if entry.l2_hash != expected_l2:
+                return False
+
+            previous_l2 = entry.l2_hash
+
+        return True
+
+    def get_latest_l2_hash(self) -> str:
+        """Get the latest L2 hash (chain head)."""
+        return self._last_l2_hash
+
+    def export(self) -> List[Dict[str, Any]]:
+        """Export proof chain as list of dictionaries."""
+        return [
+            {
+                "entry_id": e.entry_id,
+                "timestamp": e.timestamp.isoformat(),
+                "agent_id": e.agent_id,
+                "action": e.action,
+                "details": e.details,
+                "level": e.level,
+                "l1_hash": e.l1_hash,
+                "l2_hash": e.l2_hash
+            }
+            for e in self._entries
+        ]
+
+    def get_chain_summary(self) -> Dict[str, Any]:
+        """Get a summary of the proof chain."""
+        return {
+            "total_entries": len(self._entries),
+            "latest_l2_hash": self._last_l2_hash,
+            "chain_valid": self.verify_chain(),
+            "first_entry_id": self._entries[0].entry_id if self._entries else None,
+            "last_entry_id": self._entries[-1].entry_id if self._entries else None
+        }
