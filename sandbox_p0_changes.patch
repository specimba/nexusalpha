+#!/usr/bin/env python3
+"""Final P0 Integration Test Suite."""
+import sys
+sys.path.insert(0, "src")
+
+from nexus_os.bridge.server import BridgeServer, jsonrpc_result
+from nexus_os.governor.base import GovernorBase, SimpleGovernor
+from nexus_os.monitoring.trust_scorer import TrustScorer
+from nexus_os.governor.proof_chain import ProofChain
+from nexus_os.monitoring.token_guard import TokenGuard
+
+def test_p0_1_bridge():
+    """P0-1: Bridge TokenGuard + token headers."""
+    server = BridgeServer()
+    assert hasattr(server, "token_guard"), "Bridge missing token_guard"
+
+    result = jsonrpc_result({"test": True}, trace_id="tr-001", input_tokens=100, output_tokens=200)
+    assert result["x-nexus-input-tokens"] == 100
+    assert result["x-nexus-output-tokens"] == 200
+    assert result["trace_id"] == "tr-001"
+    print("✅ P0-1 PASS: Bridge token headers working")
+
+def test_p0_2_governor():
+    """P0-2: Governor hard-stop enforcement."""
+    gov = SimpleGovernor()
+    assert hasattr(gov, "token_guard"), "Governor missing token_guard"
+
+    # Test hard-stop with sufficient budget
+    result = gov.check_access("agent-001", "read")
+    assert result["decision"] == "ALLOW", f"Expected ALLOW, got {result}"
+
+    # Test enforce_hard_stop method exists
+    assert hasattr(gov, "enforce_hard_stop"), "Missing enforce_hard_stop"
+    print("✅ P0-2 PASS: Governor hard-stop integrated")
+
+def test_p0_3_trust():
+    """P0-3: Trust scoring hot-path."""
+    scorer = TrustScorer()
+    assert hasattr(scorer, "get_score_hotpath"), "Missing get_score_hotpath"
+
+    score = scorer.get_score_hotpath(
+        agent_id="agent-001",
+        Q=0.8, qmin=0.1, n=10, n0=5.0,
+        U=1.0, D_plus=0.5, R=0.2, D_minus=0.0
+    )
+    assert isinstance(score, float), f"Score should be float, got {type(score)}"
+    assert 0.0 <= score <= 1.0, f"Score out of range: {score}"
+    print(f"✅ P0-3 PASS: Trust hot-path score={score}")
+
+def test_p0_4_vap():
+    """P0-4: VAP L1+L2 audit trail."""
+    chain = ProofChain()
+
+    r1 = chain.record("agent-001", "read", {"resource": "proj-001"}, level="AUDIT")
+    r2 = chain.record("agent-002", "write", {"resource": "proj-001"}, level="AUDIT")
+
+    assert chain.verify_chain(), "Chain verification failed"
+    assert r2.l2_hash != r1.l2_hash, "L2 hashes should differ"
+
+    summary = chain.get_chain_summary()
+    assert summary["total_entries"] == 2
+    assert summary["chain_valid"] == True
+    print("✅ P0-4 PASS: VAP proof chain integrity verified")
+
+if __name__ == "__main__":
+    print("🚀 Running Final P0 Integration Tests...\n")
+    try:
+        test_p0_1_bridge()
+        test_p0_2_governor()
+        test_p0_3_trust()
+        test_p0_4_vap()
+        print("\n🎉 ALL P0 TESTS PASSED - System Ready for v3.0")
+    except Exception as e:
+        print(f"\n❌ TEST FAILED: {e}")
+        import traceback
+        traceback.print_exc()
+        sys.exit(1)
